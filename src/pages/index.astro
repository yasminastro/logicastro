---
/**
 * src/pages/index.astro
 * Fuwari 风格首页（适合心理占星 / 神话 / 长文网站）
 */

import MainGridLayout from "@/layouts/MainGridLayout.astro";
import WidgetLayout from "@/components/widget/WidgetLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("posts");

const featuredPosts = posts
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf())
  .slice(0, 6);

const latestPosts = posts
  .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf())
  .slice(0, 5);
---

<MainGridLayout title="神话与行星">

  <!-- HERO -->
  <section class="mt-20 mb-24">
    <div class="max-w-4xl">
      <p class="mb-4 text-sm tracking-[0.2em] uppercase text-neutral-500">
        Psychological Astrology Archive
      </p>

      <h1
        class="text-5xl md:text-6xl leading-tight font-semibold tracking-tight text-neutral-900 dark:text-neutral-100"
      >
        在神话与星辰之间，
        <br />
        阅读人的内在世界
      </h1>

      <p
        class="mt-8 text-lg leading-9 text-neutral-600 dark:text-neutral-400 max-w-2xl"
      >
        关于心理占星、荣格原型、神话象征与灵魂经验的长期写作。
        <br />
        这里不是每日运势网站，而是一座持续生长的数字花园。
      </p>

      <div class="mt-10 flex gap-4">
        <a
          href="/archives"
          class="px-6 py-3 rounded-2xl bg-neutral-900 text-white dark:bg-neutral-100 dark:text-black transition hover:opacity-90"
        >
          开始阅读
        </a>

        <a
          href="/about"
          class="px-6 py-3 rounded-2xl border border-neutral-300 dark:border-neutral-700 transition hover:bg-neutral-100 dark:hover:bg-neutral-900"
        >
          关于我
        </a>
      </div>
    </div>
  </section>

  <!-- SITE INTRO -->
  <section class="mb-24">
    <WidgetLayout>
      <div class="p-8 md:p-10">
        <h2 class="text-2xl font-semibold mb-6">
          关于这个网站
        </h2>

        <div
          class="space-y-5 leading-8 text-neutral-700 dark:text-neutral-300"
        >
          <p>
            这里更关注：
            行星如何成为心理经验，
            神话如何成为内在结构，
            以及占星如何作为理解灵魂的一种语言。
          </p>

          <p>
            网站内容主要包括：
            行星原型、星座神话、荣格心理学、
            阴影工作、关系投射与经典占星文本翻译。
          </p>
        </div>
      </div>
    </Card>
  </section>

  <!-- FEATURED POSTS -->
  <section class="mb-28">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-3xl font-semibold">
        精选文章
      </h2>

      <a
        href="/archives"
        class="text-sm text-neutral-500 hover:text-neutral-900 dark:hover:text-neutral-100 transition"
      >
        查看全部 →
      </a>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {
        featuredPosts.map((post) => (
          <a href={`/posts/${post.slug}`}>
            <WidgetLayout>
              <div class="p-6">
                <p class="text-sm text-neutral-500 mb-3">
                  {post.data.category}
                </p>

                <h3 class="text-2xl font-semibold leading-snug mb-4">
                  {post.data.title}
                </h3>

                <p class="leading-7 text-neutral-600 dark:text-neutral-400 line-clamp-3">
                  {post.data.description}
                </p>

                <div class="mt-6 text-sm text-neutral-500">
                  {post.data.published.toLocaleDateString("zh-CN")}
                </div>
              </div>
            </Card>
          </a>
        ))
      }
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="mb-28">
    <h2 class="text-3xl font-semibold mb-10">
      主题入口
    </h2>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-5">

      <a href="/tags/planetary-archetypes">
        <WidgetLayout>
          <div class="p-6">
            <h3 class="text-xl font-medium mb-2">
              行星原型
            </h3>

            <p class="text-sm leading-7 text-neutral-600 dark:text-neutral-400">
              土星、冥王星、月亮与内在结构
            </p>
          </div>
        </Card>
      </a>

      <a href="/tags/mythology">
        <WidgetLayout>
          <div class="p-6">
            <h3 class="text-xl font-medium mb-2">
              星座神话
            </h3>

            <p class="text-sm leading-7 text-neutral-600 dark:text-neutral-400">
              希腊神话、原型与黄道象征
            </p>
          </div>
        </Card>
      </a>

      <a href="/tags/jung">
        <WidgetLayout>
          <div class="p-6">
            <h3 class="text-xl font-medium mb-2">
              荣格心理学
            </h3>

            <p class="text-sm leading-7 text-neutral-600 dark:text-neutral-400">
              阴影、投射、阿尼玛与个体化
            </p>
          </div>
        </Card>
      </a>

      <a href="/tags/relationships">
        <WidgetLayout>
          <div class="p-6">
            <h3 class="text-xl font-medium mb-2">
              关系与投射
            </h3>

            <p class="text-sm leading-7 text-neutral-600 dark:text-neutral-400">
              爱情、亲密关系与心理动力
            </p>
          </div>
        </Card>
      </a>

      <a href="/translations">
        <WidgetLayout>
          <div class="p-6">
            <h3 class="text-xl font-medium mb-2">
              翻译计划
            </h3>

            <p class="text-sm leading-7 text-neutral-600 dark:text-neutral-400">
              心理占星经典文本翻译
            </p>
          </div>
        </Card>
      </a>

      <a href="/reading-map">
        <WidgetLayout>
          <div class="p-6">
            <h3 class="text-xl font-medium mb-2">
              阅读地图
            </h3>

            <p class="text-sm leading-7 text-neutral-600 dark:text-neutral-400">
              为初学者准备的阅读路径
            </p>
          </div>
        </Card>
      </a>

    </div>
  </section>

  <!-- LATEST POSTS -->
  <section class="mb-28">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-3xl font-semibold">
        最近更新
      </h2>
    </div>

    <div class="space-y-5">
      {
        latestPosts.map((post) => (
          <a
            href={`/posts/${post.slug}`}
            class="block border-b border-neutral-200 dark:border-neutral-800 pb-5"
          >
            <div class="flex items-start justify-between gap-6">
              <div>
                <h3 class="text-xl font-medium mb-2">
                  {post.data.title}
                </h3>

                <p class="text-neutral-600 dark:text-neutral-400 line-clamp-2">
                  {post.data.description}
                </p>
              </div>

              <div class="text-sm text-neutral-500 whitespace-nowrap">
                {post.data.published.toLocaleDateString("zh-CN")}
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ABOUT -->
  <section class="mb-32">
    <WidgetLayout>
      <div class="p-10">
        <h2 class="text-3xl font-semibold mb-6">
          关于作者
        </h2>

        <div class="max-w-3xl leading-8 text-neutral-700 dark:text-neutral-300">
          长期研究心理占星、神话原型与荣格心理学。

          <br /><br />

          关注：
          行星象征、
          神话结构、
          阴影经验，
          以及个人命运中的内在图景。

          <br /><br />

          目前主要进行：
          心理占星研究、
          长文本翻译、
          神话原型分析与中文写作。
        </div>

        <div class="mt-8">
          <a
            href="/about"
            class="text-neutral-900 dark:text-neutral-100 underline underline-offset-4"
          >
            阅读完整介绍
          </a>
        </div>
      </div>
    </Card>
  </section>

</MainGridLayout>
